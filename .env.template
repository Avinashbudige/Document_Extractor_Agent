# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/document_extraction
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# LLM Service Configuration
LLM_PROVIDER=openai  # Options: openai, anthropic, gemini
LLM_API_KEY=your-api-key-here
GEMINI_API_KEY=AIzaSyAQ.Ab8RN6LphcTumUGUOT3_EEiQXwAK896ZfYMrU_UxrEM-4yPedA
LLM_MODEL=gpt-4  # or claude-3-sonnet-20240229, or gemini-1.5-pro
LLM_TEMPERATURE=0.0
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=30

# Object Storage Configuration (S3 or S3-compatible)
S3_BUCKET=document-extraction-storage
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_REGION=us-east-1

# OCR Engine Configuration
OCR_ENGINE=tesseract  # Options: tesseract, easyocr
OCR_LANGUAGE=eng
OCR_MIN_CONFIDENCE=0.6

# Processing Configuration
MAX_FILE_SIZE_MB=50
MAX_BATCH_SIZE=100
PROCESSING_CONCURRENCY=10
PROCESSING_TIMEOUT_SECONDS=120

# Confidence Thresholds (per document type)
CONFIDENCE_THRESHOLD_INVOICE=0.85
CONFIDENCE_THRESHOLD_RECEIPT=0.80
CONFIDENCE_THRESHOLD_PURCHASE_ORDER=0.85
CONFIDENCE_THRESHOLD_INSURANCE_POLICY=0.90
CONFIDENCE_THRESHOLD_CONTRACT=0.90
CONFIDENCE_THRESHOLD_DEFAULT=0.85

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_CORS_ORIGINS=["http://localhost:3000"]
API_AUTH_ENABLED=true
API_AUTH_TOKEN_SECRET=your-secret-token-here

# Review Queue Configuration
REVIEW_QUEUE_MAX_SIZE=1000
REVIEW_QUEUE_ALERT_THRESHOLD=100

# Memory Storage Configuration (Mem0)
MEM0_API_KEY=m0-1Ye2G5j4hk9MiJeP7sJ3hr5FaXfCAymOD9ZHfh4a
MEM0_ENABLED=true

# Monitoring and Observability
METRICS_ENABLED=true
METRICS_PORT=9090
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # Options: json, text
SENTRY_DSN=  # Optional: Sentry error tracking

# Feature Flags
ENABLE_PII_ENCRYPTION=true
ENABLE_PII_REDACTION=true
ENABLE_CUSTOM_SCHEMAS=true
ENABLE_CUSTOM_VALIDATION_RULES=true
ENABLE_AUTO_CONFIG_RELOAD=true

# Performance Tuning
EXTRACTION_LATENCY_TARGET_MS=2000
UPLOAD_LATENCY_TARGET_MS=200
QUERY_LATENCY_TARGET_MS=100
MIN_THROUGHPUT_PER_NODE=100

# Security Configuration
TLS_ENABLED=true
TLS_CERT_FILE=/path/to/cert.pem
TLS_KEY_FILE=/path/to/key.pem
ENCRYPTION_KEY=your-encryption-key-for-pii
ENCRYPTION_ALGORITHM=AES-256-GCM

# Data Retention
DOCUMENT_RETENTION_DAYS=2555  # 7 years
AUDIT_LOG_RETENTION_DAYS=2555
